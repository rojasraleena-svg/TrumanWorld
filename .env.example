TRUMANWORLD_APP_ENV=development
TRUMANWORLD_API_PREFIX=/api
# 为空时不启用演示写保护；设置后，创建/启动/暂停/删除/导演注入等写操作需要管理员密码
TRUMANWORLD_DEMO_ADMIN_PASSWORD=
# 数据库连接 URL（必填）
# 格式: postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 开发环境示例: postgresql+psycopg://truman:your_password@localhost:5432/trumanworld
TRUMANWORLD_DATABASE_URL=
TRUMANWORLD_REDIS_URL=redis://localhost:6379/0
# Claude SDK 仍然只支持 Anthropic；当 LLM_PROVIDER=anthropic 时会自动回填这两个变量
TRUMANWORLD_ANTHROPIC_API_KEY=
TRUMANWORLD_ANTHROPIC_BASE_URL=
# 兼容 Anthropic 接口的模型名；若 LLM_MODEL 为空则可回退使用此值
TRUMANWORLD_ANTHROPIC_MODEL=
# 可选值: heuristic | claude_sdk | langgraph
TRUMANWORLD_AGENT_BACKEND=claude_sdk
TRUMANWORLD_AGENT_BUDGET_USD=1.0
# 统一 LLM 配置。LangGraph 直接使用该组配置；Claude SDK 仅在 provider=anthropic 时复用
TRUMANWORLD_LLM_PROVIDER=anthropic
TRUMANWORLD_LLM_MODEL=
TRUMANWORLD_LLM_API_KEY=
TRUMANWORLD_LLM_BASE_URL=
TRUMANWORLD_LANGGRAPH_REACTOR_STRUCTURED_ENABLED=false
TRUMANWORLD_LANGGRAPH_REACTOR_PROMPT_CACHE_ENABLED=true
TRUMANWORLD_LANGGRAPH_REACTOR_MAX_CONCURRENCY=4
TRUMANWORLD_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:33100","http://localhost:33100","http://127.0.0.1:3000","http://localhost:3000","http://127.0.0.1:13000","http://localhost:13000"]
TRUMANWORLD_LOG_LEVEL=DEBUG
# 浏览器端 API 地址，留空或使用相对路径时由 Next.js rewrites 代理（推荐不填）
# Docker 模式下覆盖此值以指向宿主机地址（如 http://HOST_IP:38000/api）
NEXT_PUBLIC_API_BASE_URL=
TRUMANWORLD_CLAUDE_SDK_ISOLATED_HOME_ENABLED=true
# 留空时默认使用项目根目录下的 .claude-sdk-home
TRUMANWORLD_CLAUDE_SDK_HOME_DIR=
TRUMANWORLD_CLAUDE_SDK_REACTOR_POOL_ENABLED=true

# 导演智能体配置（实验性功能）
# 统一使用 DIRECTOR_BACKEND=claude_sdk|langgraph|heuristic
TRUMANWORLD_DIRECTOR_AUTO_INTERVENTION_ENABLED=false
TRUMANWORLD_DIRECTOR_BACKEND=claude_sdk
# 导演智能体模型，留空则使用 LLM_MODEL
TRUMANWORLD_DIRECTOR_AGENT_MODEL=
# 导演决策调用频率（每 N 个 tick 执行一次 LLM 决策）
# 推荐值：5-10，既保证响应速度又控制成本，默认 5
TRUMANWORLD_DIRECTOR_DECISION_INTERVAL=5
TRUMANWORLD_SCHEDULER_INTERVAL_SECONDS=1.0
# 连续失败多少次后自动暂停（0 表示不限制）
TRUMANWORLD_SCHEDULER_MAX_CONSECUTIVE_ERRORS=5
