FROM python:3.13-slim

ARG UV_VERSION=0.9.18

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv==${UV_VERSION}

RUN useradd --create-home --shell /bin/bash appuser

ENV HOME=/home/appuser \
    PATH=/home/appuser/.local/bin:$PATH \
    UV_CACHE_DIR=/app/.uv-cache

RUN curl -fsSL https://claude.ai/install.sh | bash

USER appuser

WORKDIR /app

RUN mkdir -p /app/.uv-cache && chown -R appuser:appuser /app/.uv-cache

COPY --chown=appuser:appuser backend/pyproject.toml backend/uv.lock /app/backend/
WORKDIR /app/backend
RUN uv sync --frozen

COPY --chown=appuser:appuser backend /app/backend
COPY --chown=appuser:appuser agents /app/agents
COPY --chown=appuser:appuser scenarios /app/scenarios

EXPOSE 8000

# Railway service currently deploys directly from this Dockerfile, so startup
# must include migrations before the API boots.
CMD ["sh", "scripts/start-railway.sh"]
